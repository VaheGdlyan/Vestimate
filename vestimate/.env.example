# VESTIMATE — Local Development Environment
# Copy this file to .env and fill in all values.

APP_NAME=Vestimate
DEBUG=true
REDIS_URL=redis://localhost:6379/0

# ═══════════════════════════════════════════
# SUPABASE (Database + Auth)
# ═══════════════════════════════════════════
# Dashboard → Settings → API → Project URL
SUPABASE_URL=https://xxxxxxxx.supabase.co
# Dashboard → Settings → API → Project API Keys → service_role (secret)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUz...
# Dashboard → Settings → Database → Connection string → URI (Transaction mode, port 6543)
# IMPORTANT: Change prefix to postgresql+asyncpg://
SUPABASE_DATABASE_URL=postgresql+asyncpg://postgres.xxxxxxxx:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# ═══════════════════════════════════════════
# CLOUDFLARE R2 (Object Storage)
# ═══════════════════════════════════════════
# Dashboard → Account Home → right sidebar → Account ID
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Dashboard → R2 → Manage R2 API Tokens → Create API Token (Object Read & Write)
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Your R2 bucket name (create it first if it doesn't exist)
R2_BUCKET_NAME=vestimate-assets

# Phase 3
OPENAI_API_KEY=sk-proj-...
OPENWEATHERMAP_API_KEY=your-weather-key
MODAL_ENDPOINT_TEXT_EMBED=https://YOUR_USERNAME--vestimate-inference-text-embed.modal.run

# Phase 4: Supabase Auth (for JWT validation)
SUPABASE_JWKS_URL=https://xxxxxxxx.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_AUDIENCE=authenticated

# Phase 4: Rate limiting
RATE_LIMIT_UPLOAD=10/minute
RATE_LIMIT_RECOMMENDATION=30/minute
RATE_LIMIT_FEEDBACK=60/minute

# Phase 4: App environment & Pre-warm schedule
ENV=local
PREWARM_CRON_UTC=23:00

# Phase 4: Observability
SENTRY_DSN=your-sentry-dsn
LOGFIRE_TOKEN=your-logfire-token
PROMETHEUS_METRICS_TOKEN=your-scrape-token
TOKEN_ENCRYPTION_KEY=0sCkYAU5Np4gwWW7E4ffuryzi831doTur-LNg2FEw-A

# Phase 5: Google Calendar OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
